<script is:inline>
  const TILT_INTENSITY = 7;

  const cursor = document.getElementById('cursor');
  const cursorDot = document.getElementById('cursorDot');
  let cx=0, cy=0, dx=0, dy=0;
  window.addEventListener('pointermove', e => {
    cx = e.clientX; cy = e.clientY;
    cursorDot.style.transform = `translate(${cx}px, ${cy}px) translate(-50%,-50%)`;
  });
  function loop(){
    dx += (cx - dx) * 0.18;
    dy += (cy - dy) * 0.18;
    cursor.style.transform = `translate(${dx}px, ${dy}px) translate(-50%,-50%)`;
    requestAnimationFrame(loop);
  }
  loop();
  document.querySelectorAll('[data-hot]').forEach(el => {
    el.addEventListener('pointerenter', () => cursor.classList.add('hot'));
    el.addEventListener('pointerleave', () => cursor.classList.remove('hot'));
  });

  document.querySelectorAll('[data-scroll-to]').forEach(el => {
    el.addEventListener('click', () => {
      const id = el.getAttribute('data-scroll-to');
      const target = document.getElementById(id);
      if (target) target.scrollIntoView({behavior:'smooth'});
    });
  });

  const heroBg = document.getElementById('heroBg');
  const nameStack = document.getElementById('nameStack');
  const rows = nameStack.querySelectorAll('.row');
  const playFab = document.getElementById('playFab');
  const heroEl = document.getElementById('hero');

  let mx = 0, my = 0, tmx = 0, tmy = 0;

  window.addEventListener('pointermove', e => {
    const rect = heroEl.getBoundingClientRect();
    if (e.clientY > rect.bottom) return;
    tmx = (e.clientX / window.innerWidth - 0.5) * 2;
    tmy = (e.clientY / window.innerHeight - 0.5) * 2;
  });

  window.addEventListener('deviceorientation', e => {
    if (e.gamma != null && e.beta != null){
      tmx = Math.max(-1, Math.min(1, e.gamma / 30));
      tmy = Math.max(-1, Math.min(1, (e.beta - 45) / 30));
    }
  }, true);

  let scrollY = 0;
  const navEl = document.querySelector('.nav');
  window.addEventListener('scroll', () => {
    scrollY = window.scrollY;
    navEl.classList.toggle('scrolled', scrollY > 40);
  }, { passive:true });

  function tick(){
    mx += (tmx - mx) * 0.08;
    my += (tmy - my) * 0.08;

    const k = TILT_INTENSITY / 5;
    const scrollK = Math.min(1, scrollY / window.innerHeight);

    heroBg.style.transform = `translate3d(${-mx*18*k}px, ${-my*18*k - scrollY*0.15}px, 0) scale(${1.04 + scrollK*0.04})`;

    rows.forEach((r,i) => {
      const d = parseFloat(r.dataset.depth) || 1;
      const tx = mx * 14 * k * d;
      const ty = my * 10 * k * d - scrollY * (0.18 + i*0.06);
      const rx = -my * 3 * k;
      const ry = mx * 4 * k;
      r.style.transform = `translate3d(${tx}px, ${ty}px, 0) rotateX(${rx}deg) rotateY(${ry}deg)`;
    });

    playFab.style.transform = `translate3d(${-mx*24*k}px, ${-my*16*k}px, 0)`;

    requestAnimationFrame(tick);
  }
  tick();

  const spectrum = document.getElementById('spectrum');
  const NBARS = 64;
  const bars = [];
  for (let i=0;i<NBARS;i++){
    const b = document.createElement('div');
    b.className = 'bar';
    spectrum.appendChild(b);
    bars.push(b);
  }
  let spt = 0;
  function animSpectrum(){
    spt += 0.05;
    bars.forEach((b,i) => {
      const v = (Math.sin(spt + i*0.3) * 0.5 + 0.5) * 0.7 + Math.random() * 0.3;
      b.style.height = (v * 100) + '%';
    });
    requestAnimationFrame(animSpectrum);
  }
  animSpectrum();

  const fmt = (t) => {
    if (!isFinite(t) || t < 0) t = 0;
    const h = Math.floor(t/3600);
    const m = Math.floor((t%3600)/60);
    const s = Math.floor(t%60);
    const ss = s.toString().padStart(2,'0');
    if (h > 0) return `${h}:${m.toString().padStart(2,'0')}:${ss}`;
    return `${m}:${ss}`;
  };

  const playerPlay = document.getElementById('playerPlay');
  const cur = document.getElementById('cur');
  const durEl = document.getElementById('dur');
  const singleAudio = document.getElementById('singleAudio');
  const mixAudio = document.getElementById('mixAudio');
  const mixItem = document.getElementById('mixItem');
  const mixDur = document.getElementById('mixDur');
  const nowPlaying = document.getElementById('nowPlaying');

  const stopOther = (keep) => {
    if (keep !== singleAudio && !singleAudio.paused) singleAudio.pause();
    if (keep !== mixAudio && !mixAudio.paused) mixAudio.pause();
  };
  const playExclusive = (audio) => { stopOther(audio); return audio.play(); };

  singleAudio.addEventListener('loadedmetadata', () => { durEl.textContent = fmt(singleAudio.duration); });
  const wavePos = document.getElementById('wavePos');
  const waveFill = document.getElementById('waveFill');
  const fabRing = document.getElementById('fabProgress');
  const FAB_C = 2 * Math.PI * 86;
  if (fabRing) fabRing.style.strokeDasharray = FAB_C;
  singleAudio.addEventListener('timeupdate', () => {
    cur.textContent = fmt(singleAudio.currentTime);
    const pct = singleAudio.duration ? singleAudio.currentTime / singleAudio.duration : 0;
    const pctStr = (pct * 100) + '%';
    waveFill.style.width = pctStr;
    wavePos.style.left = pctStr;
    if (fabRing) fabRing.style.strokeDashoffset = FAB_C * (1 - pct);
  });
  singleAudio.addEventListener('play', () => {
    stopOther(singleAudio);
    playerPlay.classList.add('playing');
    playFab.classList.add('playing');
    nowPlaying.textContent = '▶ JD × SGIDONGO';
    playFab.style.animation = 'pulse 1s ease-in-out infinite';
  });
  singleAudio.addEventListener('pause', () => {
    playerPlay.classList.remove('playing');
    if (mixAudio.paused) { playFab.classList.remove('playing'); playFab.style.animation = ''; }
  });
  singleAudio.addEventListener('ended', () => {
    waveFill.style.width = '0%';
    wavePos.style.left = '0%';
    if (fabRing) fabRing.style.strokeDashoffset = FAB_C;
  });

  playerPlay.addEventListener('click', () => {
    if (singleAudio.paused) playExclusive(singleAudio); else singleAudio.pause();
  });

  const waveEl = document.getElementById('wave');
  const seekSingle = (e) => {
    const r = waveEl.getBoundingClientRect();
    const pct = Math.max(0, Math.min(1, (e.clientX - r.left) / r.width));
    if (isFinite(singleAudio.duration)) singleAudio.currentTime = pct * singleAudio.duration;
  };
  let scrubSingle = false;
  waveEl.addEventListener('mousedown', (e) => { scrubSingle = true; seekSingle(e); });
  window.addEventListener('mousemove', (e) => { if (scrubSingle) seekSingle(e); });
  window.addEventListener('mouseup', () => { scrubSingle = false; });

  const singleVol = document.getElementById('singleVol');
  singleVol.addEventListener('input', () => { singleAudio.volume = parseFloat(singleVol.value); });

  const fabLabel = document.getElementById('fabLabel');
  mixAudio.addEventListener('loadedmetadata', () => {
    mixDur.textContent = fmt(mixAudio.duration);
    if (fabLabel) fabLabel.textContent = `${fmt(mixAudio.duration)} — Latest Set`;
  });
  mixAudio.addEventListener('play', () => {
    stopOther(mixAudio);
    mixItem.classList.add('playing');
    playFab.classList.add('playing');
    mixDur.textContent = 'Playing';
    nowPlaying.textContent = '▶ LIVE AT MARKS PUB';
    playFab.style.animation = 'pulse 1s ease-in-out infinite';
  });
  mixAudio.addEventListener('pause', () => {
    mixItem.classList.remove('playing');
    if (isFinite(mixAudio.duration)) mixDur.textContent = fmt(mixAudio.duration);
    if (singleAudio.paused) { playFab.classList.remove('playing'); playFab.style.animation = ''; }
  });

  const mixPlayBtn = document.getElementById('mixPlayBtn');
  const mixCtrlPlay = document.getElementById('mixCtrlPlay');
  const mixCtrlIcon = document.getElementById('mixCtrlIcon');
  const mixCtrlCur = document.getElementById('mixCtrlCur');
  const mixCtrlDur = document.getElementById('mixCtrlDur');
  const mixScrub = document.getElementById('mixScrub');
  const mixFill = document.getElementById('mixFill');
  const mixKnob = document.getElementById('mixKnob');
  const mixVol = document.getElementById('mixVol');
  const toggleMix = () => { if (mixAudio.paused) playExclusive(mixAudio); else mixAudio.pause(); };
  mixPlayBtn.addEventListener('click', (e) => { e.stopPropagation(); toggleMix(); });
  mixCtrlPlay.addEventListener('click', (e) => { e.stopPropagation(); toggleMix(); });
  mixItem.addEventListener('click', (e) => {
    if (e.target.closest('.controls') || e.target.closest('.play-btn')) return;
    toggleMix();
  });

  const setPlayIcon = (pause) => {
    mixCtrlIcon.innerHTML = pause
      ? '<rect x="3" y="2" width="3.5" height="12"></rect><rect x="9.5" y="2" width="3.5" height="12"></rect>'
      : '<polygon points="3,2 13,8 3,14"></polygon>';
  };
  mixAudio.addEventListener('play', () => setPlayIcon(true));
  mixAudio.addEventListener('pause', () => setPlayIcon(false));
  mixAudio.addEventListener('loadedmetadata', () => { mixCtrlDur.textContent = fmt(mixAudio.duration); });
  mixAudio.addEventListener('timeupdate', () => {
    mixCtrlCur.textContent = fmt(mixAudio.currentTime);
    const pct = mixAudio.duration ? (mixAudio.currentTime / mixAudio.duration) * 100 : 0;
    mixFill.style.width = pct + '%';
    mixKnob.style.left = pct + '%';
  });
  const seek = (e) => {
    const r = mixScrub.getBoundingClientRect();
    const pct = Math.max(0, Math.min(1, (e.clientX - r.left) / r.width));
    if (isFinite(mixAudio.duration)) mixAudio.currentTime = pct * mixAudio.duration;
  };
  let scrubbing = false;
  mixScrub.addEventListener('mousedown', (e) => { e.stopPropagation(); scrubbing = true; seek(e); });
  window.addEventListener('mousemove', (e) => { if (scrubbing) seek(e); });
  window.addEventListener('mouseup', () => { scrubbing = false; });
  mixVol.addEventListener('input', (e) => { e.stopPropagation(); mixAudio.volume = parseFloat(mixVol.value); });
  mixVol.addEventListener('click', (e) => e.stopPropagation());

  playFab.addEventListener('click', () => {
    if (singleAudio.paused && mixAudio.paused) playExclusive(singleAudio);
    else { singleAudio.pause(); mixAudio.pause(); }
  });

  document.getElementById('bookForm').addEventListener('submit', e => {
    e.preventDefault();
    document.getElementById('formResp').style.display = 'block';
  });

  const io = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('on'); });
  }, { threshold: 0.12 });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));

  const navUl = document.querySelector('.nav ul');
  const menuBtnEl = document.getElementById('menuBtn');
  menuBtnEl.addEventListener('click', () => {
    const open = !navUl.classList.contains('open');
    navUl.classList.toggle('open', open);
    navEl.classList.toggle('menu-open', open);
    menuBtnEl.querySelector('span').textContent = open ? 'CLOSE' : 'MENU';
  });
  navUl.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
    navUl.classList.remove('open');
    navEl.classList.remove('menu-open');
    menuBtnEl.querySelector('span').textContent = 'MENU';
  }));
</script>
</body>
