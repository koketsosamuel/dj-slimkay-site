  .mix .play-btn .pbars span{display:block;width:3px;height:12px;background:currentColor}
  .mix.playing .play-btn{background:var(--red);border-color:var(--red);color:#fff}
  .mix.playing .play-btn .tri{display:none}
  .mix.playing .play-btn .pbars{display:flex}
  .mix .controls{
    grid-column:1 / -1;display:none;margin-top:16px;
    padding:14px 16px;background:rgba(255,23,68,.05);border:1px solid rgba(255,23,68,.2);
    display:none;gap:14px;align-items:center;
  }
  .mix.playing .controls{display:flex}
  .mix .controls audio{display:none}
  .mix .c-btn{
    width:36px;height:36px;border-radius:50%;border:1.5px solid var(--ink);background:transparent;
    display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--ink);flex-shrink:0;
    padding:0;transition:background .2s,border-color .2s,color .2s;
  }
  .mix .c-btn:hover{background:var(--red);border-color:var(--red);color:#fff}
  .mix .c-btn svg{width:14px;height:14px;fill:currentColor}
