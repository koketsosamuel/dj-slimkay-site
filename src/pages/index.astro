  .mix .c-scrub{flex:1;height:4px;background:rgba(0,0,0,.08);position:relative;cursor:pointer;border-radius:2px}
  .mix .c-scrub .fill{position:absolute;top:0;left:0;height:100%;background:var(--red);width:0%;border-radius:2px}
  .mix .c-scrub .knob{position:absolute;top:50%;width:12px;height:12px;background:var(--red);border-radius:50%;transform:translate(-50%,-50%);left:0%;box-shadow:0 0 0 3px rgba(255,23,68,.2)}
  .mix .c-vol{display:flex;align-items:center;gap:8px;flex-shrink:0}
  .mix .c-vol svg{width:16px;height:16px;fill:var(--ink-dim)}
