    -webkit-appearance:none;appearance:none;width:70px;height:3px;background:rgba(0,0,0,.1);border-radius:2px;outline:none;cursor:pointer;
  }
  .mix .c-vol input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;appearance:none;width:10px;height:10px;background:var(--red);border-radius:50%;cursor:pointer}
  .mix .c-vol input[type=range]::-moz-range-thumb{width:10px;height:10px;background:var(--red);border:none;border-radius:50%;cursor:pointer}
  @media (max-width:720px){.mix .c-vol{display:none}}
  .mix.playing{padding-left:16px;padding-right:16px;background:rgba(255,23,68,.04)}

  @media (min-width:900px){
    .mix{grid-template-columns:60px 1fr 1fr auto auto}
