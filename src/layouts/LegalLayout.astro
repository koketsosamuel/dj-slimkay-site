---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const siteUrl = 'https://slimkay.co.za';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const isProduction = import.meta.env.PROD;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta name="theme-color" content="#080304" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  {isProduction && (
    <>
      <link rel="preconnect" href="https://umami.brightsync.co.za" />
      <link rel="dns-prefetch" href="https://umami.brightsync.co.za" />
      <script is:inline defer src="https://umami.brightsync.co.za/script.js" data-website-id="ca25350c-cb05-4581-9548-1b3db8e4e98b"></script>
    </>
  )}
  <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;700;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    :root{--bg:#080304;--panel:#12070a;--ink:#fbe7e3;--dim:rgba(251,231,227,.68);--line:rgba(251,231,227,.14);--red:#ff1744}
    *{box-sizing:border-box}
    html,body{margin:0;background:var(--bg);color:var(--ink);font-family:Archivo,system-ui,sans-serif;line-height:1.6}
    body{min-height:100vh;background:radial-gradient(ellipse 70% 45% at 50% -10%, rgba(255,23,68,.2), transparent 70%), var(--bg)}
    a{color:inherit}
    .shell{width:min(880px,calc(100% - 40px));margin:0 auto;padding:28px 0 72px}
    header{display:flex;align-items:center;justify-content:space-between;gap:20px;padding:18px 0 56px;font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.14em;text-transform:uppercase}
    header a{text-decoration:none}
    .brand{font-weight:700}
    .back{color:var(--dim)}
    main{border-top:1px solid var(--line);padding-top:44px}
    h1{font-size:clamp(42px,9vw,88px);line-height:.9;letter-spacing:-.04em;text-transform:uppercase;margin:0 0 24px;font-weight:900}
    h2{font-size:20px;line-height:1.2;margin:36px 0 10px;text-transform:uppercase;letter-spacing:.02em}
    p,li{color:var(--dim);font-size:16px}
    ul{padding-left:22px}
    .updated{font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--red);margin-bottom:28px}
    footer{border-top:1px solid var(--line);margin-top:52px;padding-top:24px;color:var(--dim);font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.12em;text-transform:uppercase}
  </style>
</head>
<body>
  <div class="shell">
    <header>
      <a class="brand" href="/">SLIMKAY</a>
      <a class="back" href="/#book">Bookings</a>
    </header>
    <main>
      <slot />
    </main>
    <footer>© 2026 Slimkay · Soshanguve · Pretoria</footer>
  </div>
</body>
</html>
